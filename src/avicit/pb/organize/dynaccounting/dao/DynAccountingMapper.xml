<!-- 查询 DYN_ACCOUNTING（导出） -->
<select id="searchDynAccountingForExport" parameterType="java.util.Map" resultMap="DynAccountingDTOMap">
	select
	<include refid="commonColums"/>
	from DYN_ACCOUNTING t1
	<where>
		<if test="bean != null">
			<include refid="commonWhereAnd"/>
			<include refid="defaultWhereAnd"/>
		</if>
		<if test="ids != null and ids.size > 0">
			and t1.id in
			<foreach collection="ids" item="item" index="index" open="(" separator="," close=")">
				#{item}
			</foreach>
		</if>
	</where>
	order by t1.creation_date desc
</select>
<!-- 主键查询对象 DYN_ACCOUNTING -->
<select id="findDynAccountingById" parameterType="java.lang.String" resultMap="DynAccountingDTOMap">
