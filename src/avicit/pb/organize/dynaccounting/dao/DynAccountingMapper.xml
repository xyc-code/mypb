	t1.LAST_UPDATED_BY,
	t1.CREATION_DATE,
	t1.LAST_UPDATE_DATE,
	t1.SUBJECT_MATTER,
	t1.EXPENDITURE,
	t1.BALANCE,
	t1.RARTY_NAME,
	t1.STATUS,
	t1.INCOME,
	t1.VERSION,
	t1.ID,
