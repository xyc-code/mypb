<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="avicit.pb.dyndemocracy.dao.DynDemocracyDAO">
<resultMap id="DynDemocracyDTOMap" type="avicit.pb.dyndemocracy.dto.DynDemocracyDTO">
	<result property="createdBy" column="CREATED_BY" jdbcType="VARCHAR" />
	<result property="democracyDate" column="DEMOCRACY_DATE" jdbcType="TIMESTAMP" />
	<result property="lastUpdatedBy" column="LAST_UPDATED_BY" jdbcType="VARCHAR" />
	<result property="creationDate" column="CREATION_DATE" jdbcType="TIMESTAMP" />
	<result property="lastUpdateDate" column="LAST_UPDATE_DATE" jdbcType="TIMESTAMP" />
	<result property="democracyEndDate" column="DEMOCRACY_END_DATE" jdbcType="TIMESTAMP" />
    <result property="leadName" column="LEAD_NAME" jdbcType="CLOB" javaType="String" />
	<result property="leadJoin" column="LEAD_JOIN" jdbcType="VARCHAR" />
	<result property="democracyDept" column="DEMOCRACY_DEPT" jdbcType="VARCHAR" />
	<result property="version" column="VERSION" jdbcType="DECIMAL" />
	<result property="id" column="ID" jdbcType="VARCHAR" />
	<result property="createdDept" column="CREATED_DEPT" jdbcType="VARCHAR" />
	<result property="orgIdentity" column="ORG_IDENTITY" jdbcType="VARCHAR" />
	<result property="lastUpdateIp" column="LAST_UPDATE_IP" jdbcType="VARCHAR" />
	<result property="activityalias_" column="activityalias_" jdbcType="VARCHAR" />
	<result property="businessstate_" column="businessstate_" jdbcType="VARCHAR" />
	<result property="assigneenames_" column="assigneenames_" jdbcType="VARCHAR" />
</resultMap>
<sql id="commonColums">
	t1.CREATED_BY,
	t1.DEMOCRACY_DATE,
	t1.LAST_UPDATED_BY,
	t1.CREATION_DATE,
	t1.LAST_UPDATE_DATE,
	t1.DEMOCRACY_END_DATE,
	t1.LEAD_NAME,
	t1.LEAD_JOIN,
	t1.DEMOCRACY_DEPT,
	t1.VERSION,
	t1.ID,
	t1.CREATED_DEPT,
	t1.ORG_IDENTITY,
	t1.LAST_UPDATE_IP</sql>
<!-- 默认查询条件 -->
<sql id="defaultWhereAnd">
	<if test="bean.orgIdentity != null and bean.orgIdentity != ''">
		and t1.org_identity = #{bean.orgIdentity}
	</if>
</sql>
<sql id="commonWhereAnd">
	<if test="bean.createdBy != null and bean.createdBy != ''">
		and t1.CREATED_BY = #{bean.createdBy}
	</if>
	<if test="bean.democracyDateBegin != null">
		and t1.DEMOCRACY_DATE &gt;= #{bean.democracyDateBegin}
	</if>
	<if test="bean.democracyDateEnd != null">
		and t1.DEMOCRACY_DATE &lt;= #{bean.democracyDateEnd}
	</if>
	<if test="bean.lastUpdatedBy != null and bean.lastUpdatedBy != ''">
		and t1.LAST_UPDATED_BY = #{bean.lastUpdatedBy}
	</if>
	<if test="bean.creationDateBegin != null">
		and t1.CREATION_DATE &gt;= #{bean.creationDateBegin}
	</if>
	<if test="bean.creationDateEnd != null">
		and t1.CREATION_DATE &lt;= #{bean.creationDateEnd}
	</if>
	<if test="bean.lastUpdateDateBegin != null">
		and t1.LAST_UPDATE_DATE &gt;= #{bean.lastUpdateDateBegin}
	</if>
	<if test="bean.lastUpdateDateEnd != null">
		and t1.LAST_UPDATE_DATE &lt;= #{bean.lastUpdateDateEnd}
	</if>
	<if test="bean.democracyEndDateBegin != null">
		and t1.DEMOCRACY_END_DATE &gt;= #{bean.democracyEndDateBegin}
	</if>
	<if test="bean.democracyEndDateEnd != null">
		and t1.DEMOCRACY_END_DATE &lt;= #{bean.democracyEndDateEnd}
	</if>
	<if test="bean.leadName != null and bean.leadName != ''">
		and t1.LEAD_NAME like concat(concat('%',#{bean.leadName}),'%')
	</if>
	<if test="bean.leadJoin != null and bean.leadJoin != ''">
		and t1.LEAD_JOIN like concat(concat('%',#{bean.leadJoin}),'%')
	</if>
	<if test="bean.democracyDept != null and bean.democracyDept != ''">
		and t1.DEMOCRACY_DEPT like concat(concat('%',#{bean.democracyDept}),'%')
	</if>
	<if test="bean.version != null">
		and t1.VERSION = #{bean.version}
	</if>
	<if test="bean.id != null and bean.id != ''">
		and t1.ID = #{bean.id}
	</if>
	<if test="bean.createdDept != null and bean.createdDept != ''">
		and t1.CREATED_DEPT = #{bean.createdDept}
	</if>
	<if test="bean.lastUpdateIp != null and bean.lastUpdateIp != ''">
		and t1.LAST_UPDATE_IP = #{bean.lastUpdateIp}
	</if>
</sql>
<sql id="commonWhereOr">
	<trim prefix="(" suffix=")" prefixOverrides="or">
	<if test="bean.createdBy != null and bean.createdBy != ''">
		or t1.CREATED_BY = #{bean.createdBy}
	</if>
	<if test="bean.democracyDateBegin != null">
		or t1.DEMOCRACY_DATE &gt;= #{bean.democracyDateBegin}
	</if>
	<if test="bean.democracyDateEnd != null">
		or t1.DEMOCRACY_DATE &lt;= #{bean.democracyDateEnd}
	</if>
	<if test="bean.lastUpdatedBy != null and bean.lastUpdatedBy != ''">
		or t1.LAST_UPDATED_BY = #{bean.lastUpdatedBy}
	</if>
	<if test="bean.creationDateBegin != null">
		or t1.CREATION_DATE &gt;= #{bean.creationDateBegin}
	</if>
	<if test="bean.creationDateEnd != null">
		or t1.CREATION_DATE &lt;= #{bean.creationDateEnd}
	</if>
	<if test="bean.lastUpdateDateBegin != null">
		or t1.LAST_UPDATE_DATE &gt;= #{bean.lastUpdateDateBegin}
	</if>
	<if test="bean.lastUpdateDateEnd != null">
		or t1.LAST_UPDATE_DATE &lt;= #{bean.lastUpdateDateEnd}
	</if>
	<if test="bean.democracyEndDateBegin != null">
		or t1.DEMOCRACY_END_DATE &gt;= #{bean.democracyEndDateBegin}
	</if>
	<if test="bean.democracyEndDateEnd != null">
		or t1.DEMOCRACY_END_DATE &lt;= #{bean.democracyEndDateEnd}
	</if>
	<if test="bean.leadName != null and bean.leadName != ''">
		or t1.LEAD_NAME like concat(concat('%',#{bean.leadName}),'%')
	</if>
	<if test="bean.leadJoin != null and bean.leadJoin != ''">
		or t1.LEAD_JOIN like concat(concat('%',#{bean.leadJoin}),'%')
	</if>
	<if test="bean.democracyDept != null and bean.democracyDept != ''">
		or t1.DEMOCRACY_DEPT like concat(concat('%',#{bean.democracyDept}),'%')
	</if>
	<if test="bean.version != null">
		or t1.VERSION = #{bean.version}
	</if>
	<if test="bean.id != null and bean.id != ''">
		or t1.ID = #{bean.id}
	</if>
	<if test="bean.createdDept != null and bean.createdDept != ''">
		or t1.CREATED_DEPT = #{bean.createdDept}
	</if>
	<if test="bean.lastUpdateIp != null and bean.lastUpdateIp != ''">
		or t1.LAST_UPDATE_IP = #{bean.lastUpdateIp}
	</if>
	</trim>
</sql>
<sql id="commonBpmWhereAnd">
    <if test="bean.bpmType != null and bean.bpmType != '' and bean.bpmType == 'my'">
        and exists (select 1 from BPM_CLIENT_HIST_TASK_V os where os.task_b_id_ = t1.id and os.assignee_ = #{bean.currUserId})
    </if>
    <if test="bean.bpmState != null and bean.bpmState != '' and bean.bpmState != 'all'">
        and v.businessstate_ = #{bean.bpmState}
    </if>
</sql>
<sql id="commonBpmColums">
    v.activityalias_,
    v.businessstate_,
	v.assigneenames_,
</sql>
<sql id="commonOrderBy">
	<choose>
		<when test="pOrderBy != null and pOrderBy != ''">
			order by ${pOrderBy}
		</when>
		<otherwise>
			order by t1.creation_date desc
		</otherwise>
	</choose>
</sql>

<!-- 分页查询 DYN_DEMOCRACY -->
<select id="searchDynDemocracyByPage" parameterType="java.util.Map" resultMap="DynDemocracyDTOMap">
	select
	<include refid="commonBpmColums"/>
	<include refid="commonColums"/>
	from DYN_DEMOCRACY t1 left join BPM_CLIENT_HIST_PROCINST_V v on t1.id = v.formid_
<where>
	<if test="bean != null">
		<choose>
			<when test="keyWord != null and keyWord != '' ">
				<include refid="commonWhereOr"/>
				<include refid="commonBpmWhereAnd"/>
			</when>
			<otherwise>
				<include refid="commonWhereAnd"/>
				<include refid="commonBpmWhereAnd"/>
			</otherwise>
		</choose>
		<include refid="defaultWhereAnd"/>
	</if>
</where>
<include refid="commonOrderBy"></include>
</select>
<!-- 查询列表 DYN_DEMOCRACY -->
<select id="searchDynDemocracy" parameterType="java.util.Map" resultMap="DynDemocracyDTOMap">
	select
	<include refid="commonBpmColums"/>
	<include refid="commonColums"/>
	from DYN_DEMOCRACY t1 left join sys_bpm_hist_procinst v on t1.id = v.formid_
<where>
	<if test="bean != null">
		<choose>
			<when test="keyWord != null and keyWord != '' ">
				<include refid="commonWhereOr"/>
				<include refid="commonBpmWhereAnd"/>
			</when>
			<otherwise>
				<include refid="commonWhereAnd"/>
				<include refid="commonBpmWhereAnd"/>
			</otherwise>
		</choose>
		<include refid="defaultWhereAnd"/>
	</if>
</where>
<include refid="commonOrderBy"></include>
</select>
<!-- 查询 DYN_DEMOCRACY（导出） -->
<select id="searchDynDemocracyForExport" parameterType="java.util.Map" resultMap="DynDemocracyDTOMap">
	select
	<include refid="commonBpmColums"/>
	<include refid="commonColums"/>
	from DYN_DEMOCRACY t1 left join sys_bpm_hist_procinst v on t1.id = v.formid_
<where>
	<if test="bean != null">
		<include refid="commonWhereAnd"/>
		<include refid="commonBpmWhereAnd"/>
		<include refid="defaultWhereAnd"/>
	</if>
	<if test="ids != null and ids.size > 0">
		and t1.id in
		<foreach collection="ids" item="item" index="index" open="(" separator="," close=")">
			#{item}
		</foreach>
	</if>
</where>
	order by t1.creation_date desc
</select>
<!-- 主键查询对象 DYN_DEMOCRACY -->
<select id="findDynDemocracyById" parameterType="java.lang.String" resultMap="DynDemocracyDTOMap">
	select
	<include refid="commonColums"/>
	from DYN_DEMOCRACY t1
	where t1.id = #{id}
</select>
